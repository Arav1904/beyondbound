MONGODB_URI=mongodb+srv://<user>:<pass>@cluster.mongodb.net/beyond-bound?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/beyond-bound
PORT=5000

# ─── Environment ──────────────────────────────────────────────────────────────
# LOCAL DEV:  NODE_ENV=development
# PRODUCTION: NODE_ENV=production
NODE_ENV=development

# ─── CORS ─────────────────────────────────────────────────────────────────────
# LOCAL DEV:  CORS_ORIGIN=http://localhost:5173
# PRODUCTION: CORS_ORIGIN=https://www.beyondbound.info
# (comma-separate multiple origins if needed)
CORS_ORIGIN=http://localhost:5173

# ─── Auth ─────────────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=7d

# ─── Admin ────────────────────────────────────────────────────────────────────
ADMIN_ALLOWLIST=beyondbound889@gmail.com,admin@beyondbound.com
ADMIN_BOOTSTRAP_EMAIL=beyondbound889@gmail.com
ADMIN_API_KEY=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET

# ─── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_MAX=250
AUTH_RATE_LIMIT_MAX=40

# ─── Webhooks ─────────────────────────────────────────────────────────────────
ORDER_CONFIRMATION_WEBHOOK_URL=

# ─── PayU ─────────────────────────────────────────────────────────────────────
# Get PAYU_MERCHANT_KEY and PAYU_MERCHANT_SALT from your PayU merchant dashboard.
PAYU_MERCHANT_KEY=
PAYU_MERCHANT_SALT=

# LOCAL DEV:  PAYU_ENV=production  (use real PayU with ₹1 test charge)
# PRODUCTION: PAYU_ENV=production
PAYU_ENV=production

# LOCAL DEV:  PAYU_BASE_URL=https://secure.payu.in/_payment
# PRODUCTION: PAYU_BASE_URL=https://secure.payu.in/_payment
# (use https://sandboxsecure.payu.in/_payment for PayU sandbox testing)
PAYU_BASE_URL=https://secure.payu.in/_payment

# PAYU_CALLBACK_URL = backend endpoint PayU redirects the browser to after payment.
# Must be a URL the browser can reach (localhost works for local dev).
# LOCAL DEV:  PAYU_CALLBACK_URL=http://localhost:5000/api/orders/payu/callback
# PRODUCTION: PAYU_CALLBACK_URL=https://www.beyondbound.info/api/orders/payu/callback
PAYU_CALLBACK_URL=http://localhost:5000/api/orders/payu/callback

# PAYU_RETURN_URL = frontend SPA root that reads ?status=success|failed query params.
# LOCAL DEV:  PAYU_RETURN_URL=http://localhost:5173
# PRODUCTION: PAYU_RETURN_URL=https://www.beyondbound.info
PAYU_RETURN_URL=http://localhost:5173

# Session TTL in minutes (how long a pending PaymentSession is valid)
PAYU_SESSION_TTL_MINUTES=30
